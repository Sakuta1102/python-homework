# Kyuubi 数据查询账号
# 来源：DataLeap / 数据平台为你分配的 Kyuubi 账号密码
KYUUBI_USERNAME=yourname
KYUUBI_PASSWORD=xxxxxxxxxx

# 飞书企业自建应用凭证
# 来源：飞书开放平台 → 我的应用 → 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书自定义机器人 webhook（清洗结果完成后推送通知）
# 来源：群聊设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 webhook 地址
FEISHU_NOTIFY_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书目标文档资源 token
# 来源：飞书电子表格 / 知识库页面 URL 中的 token 段
FEISHU_SPREADSHEET_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_WIKI_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web 上传"玩家数据黑产检查"功能写入的目标 sheet_id
# 在 FEISHU_SPREADSHEET_TOKEN 那张电子表格里建一个 sheet,
# 复制 sheet_id(电子表格底部 tab 上右键查看,或表格 URL 末尾)
FEISHU_BLACKLIST_CHECK_SHEET_ID=xxxxxx

# 黑产关键词词表所在 sheet(第一列每个非空单元格 = 一个关键词)
# 服务启动时拉一次,改完关键词需要重启服务才生效
FEISHU_BLACKLIST_KEYWORDS_SHEET_ID=xxxxxx
